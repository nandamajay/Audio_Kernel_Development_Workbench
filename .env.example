# -- QGenie API Configuration -------------------------------------------------
QGENIE_API_KEY=
QGENIE_PROVIDER_URL=https://qgenie-chat.qualcomm.com/v1
QGENIE_DEFAULT_MODEL=auto
QGENIE_AVAILABLE_MODELS=claude-sonnet-4,qwen3,qgenie-pro,claude-haiku-4

# -- Application Configuration ------------------------------------------------
FLASK_SECRET_KEY=change_me_in_production
FLASK_ENV=development
FLASK_PORT=5000
DEBUG=true

# -- User Personalisation -----------------------------------------------------
USER_DISPLAY_NAME=

# -- Workspace & Path Configuration ------------------------------------------
HOST_WORKSPACE_PATH=/local/mnt/workspace/AUDIO_KERNEL_DEVELOPMENT_WORKBENCH(AKDW)
WORKSPACE_PATH=/app/workspace
KERNEL_SRC_PATH=/app/kernel
PATCHES_PATH=/app/patches
LOGS_PATH=/app/workspace/logs
SESSIONS_DB_PATH=/app/sessions/akdw_sessions.db

# -- PatchWise Configuration --------------------------------------------------
PATCHWISE_DEFAULT_COMMITS=1
PATCHWISE_SUBSYSTEM=sound/soc/qcom

# -- Triage Configuration -----------------------------------------------------
TRIAGE_AUTO_ANALYSE=true
